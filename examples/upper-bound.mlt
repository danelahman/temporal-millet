grades time-upper-bound

(* Correctly accepted by the typechecker. *)
let foo1 () = 
  box 3 1 as r in
  delay 1;
  delay 2;
  unbox r as y in
  y

(* Correctly accepted by the typechecker. *)
let foo2 () = 
  box 3 1 as r in
  delay 2;
  unbox r as y in
  y

(* Correctly rejected by the typechecker. *)
(*
let foo3 () = 
  box 3 1 as r in
  delay 4;
  unbox r as y in
  y
*)

run foo1 ()
run foo2 ()
