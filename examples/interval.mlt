(* Correctly accepted by the typechecker. *)
let foo1 () = 
  box (1,4) 1 as r in
  let _ = delay 1 in
  let _ = delay 2 in
  unbox r as y in
  1

(* Correctly accepted by the typechecker. *)
let foo2 () = 
  box (1,4) 1 as r in
  let _ = delay 1 in
  let _ = delay 2 in
  unbox r as y in
  y

(* Correctly accepted by the typechecker. *)
let foo3 () = 
  let x = 7 in
  box (1,4) 1 as r in
  let _ = delay 1 in
  let _ = delay 2 in
  let z = 3 in
  unbox r as y in
  y + z

(* Correctly rejected by the typechecker. *)
(* TODO: But as 7 is constant and stable, would be nice if it were not rejected. *)
