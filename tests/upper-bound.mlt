resources time-upper-bound

(* Correctly accepted by the typechecker. *)
let foo1 () = 
  box 3 1 as r in
  let _ = delay 1 in
  let _ = delay 2 in
  unbox r as y in
  y

(* Correctly accepted by the typechecker. *)
let foo2 () = 
  box 3 1 as r in
  let _ = delay 2 in
  unbox r as y in
  y

(* Correctly rejected by the typechecker. *)
(*
let foo3 () = 
  box 3 1 as r in
  let _ = delay 4 in
  unbox r as y in
  y
*)

run foo1 ()
run foo2 ()
